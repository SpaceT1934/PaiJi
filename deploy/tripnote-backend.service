[Unit]
Description=TripNote FastAPI backend
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/opt/tripnote-backend
EnvironmentFile=/opt/tripnote-backend/.env
ExecStart=/opt/tripnote-backend/.venv/bin/python -m uvicorn app.main:app --host 127.0.0.1 --port 8787
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
